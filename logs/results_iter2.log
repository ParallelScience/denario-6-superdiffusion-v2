**Code Explanation:**

This script performs the full phase-space mapping and Lévy-stable analysis for Step 7. It:

1. Loads both validated datasets and recomputes velocity increments for all N configurations and β classes
2. Fits Lévy-stable distributions using `scipy.stats.levy_stable` to extract stability index α_stable and skewness β_stable for each configuration
3. Recomputes Hill estimator μ (tail index) for each group using a stable tail fraction (10th percentile threshold)
4. Retrieves EAMSD α_emp values from Step 6 results and constructs the (α_emp, μ) state-space map
5. Computes empirical KL divergence between point-vortex increment PDFs and each Lévy walk β class, for early (first 25%) and late (last 25%) trajectory segments separately
6. Derives theoretical α_theory(N) = 3 - μ(N) using the empirical Hill μ(N) as the finite-N correction to the Cauchy baseline (μ=2)
7. Produces a 4-panel figure: (a) state-space map, (b) KL divergence vs N for early/late windows, (c) theoretical vs empirical α with residuals, (d) increment PDFs for N=40 vs best-matching Lévy walk with Lévy-stable fit overlaid

Units: positions in meters (m), velocities in m/s, time in seconds (s), MSD in m², Hill μ is dimensionless, α_emp is dimensionless.

**Python Code:**

```python
import numpy as np
import os
import matplotlib
matplotlib.rcParams['text.usetex'] = False
import matplotlib.pyplot as plt
from scipy.stats import levy_stable
from scipy.optimize import minimize_scalar
import warnings
from datetime import datetime

def load_datasets(data_dir):
    """Load validated point-vortex and Lévy walk datasets from disk.
    
    Parameters
    ----------
    data_dir : str
        Directory containing validated .npz files.
    
    Returns
    -------
    pv : np.ndarray
        Point-vortex structured array.
    lw : np.ndarray
        Lévy walk structured array.
    """
    pv = np.load(os.path.join(data_dir, 'point_vortex_tracers_validated.npz'))['data']
    lw = np.load(os.path.join(data_dir, 'levy_walk_trajectories_validated.npz'))['data']
    return pv, lw


def extract_increments(arr, group_field, group_val, id_field, time_field, x_field, y_field,
                       segment=None):
    """Extract absolute velocity increments (dx, dy) for a given group.
    
    Parameters
    ----------
    arr : np.ndarray
        Structured array.
    group_field : str
        Field name for grouping (e.g., 'n_vortices' or 'beta').
    group_val : scalar
        Value of group_field to select.
    id_field : str
        Field name for trajectory ID.
    time_field : str
        Field name for time.
    x_field : str
        Field name for x position (m).
    y_field : str
        Field name for y position (m).
    segment : str or None
        'early' for first 25% of steps, 'late' for last 25%, None for all.
    
    Returns
    -------
    dx_all : np.ndarray
        All x-increments (m).
    dy_all : np.ndarray
        All y-increments (m).
    abs_all : np.ndarray
        Absolute increments (m).
    """
    mask = arr[group_field] == group_val
    sub = arr[mask]
    traj_ids = sorted(np.unique(sub[id_field]).tolist())
    dx_list, dy_list = [], []
    for tid in traj_ids:
        tmask = sub[id_field] == tid
        traj = sub[tmask]
        sort_idx = np.argsort(traj[time_field])
        x = traj[x_field][sort_idx]
        y = traj[y_field][sort_idx]
        T = len(x)
        if segment == 'early':
            end = max(2, int(0.25 * T))
            x = x[:end]
            y = y[:end]
        elif segment == 'late':
            start = min(T - 2, int(0.75 * T))
            x = x[start:]
            y = y[start:]
        dx = np.diff(x)
        dy = np.diff(y)
        dx_list.append(dx)
        dy_list.append(dy)
    dx_all = np.concatenate(dx_list)
    dy_all = np.concatenate(dy_list)
    abs_all = np.concatenate([np.abs(dx_all), np.abs(dy_all)])
    return dx_all, dy_all, abs_all


def hill_estimator(data, tail_fraction=0.10):
    """Compute Hill estimator of tail index μ for heavy-tailed data.
    
    Parameters
    ----------
    data : np.ndarray
        Array of positive values (absolute increments, m).
    tail_fraction : float
        Fraction of data in the upper tail used for estimation.
    
    Returns
    -------
    mu : float
        Hill tail index estimate (dimensionless).
    """
    n = len(data)
    k = max(3, int(tail_fraction * n))
    sorted_data = np.sort(data)
    tail = sorted_data[-k:]
    threshold = tail[0]
    if threshold <= 0:
        return np.nan
    log_ratios = np.log(tail[1:] / threshold)
    mean_log = np.mean(log_ratios)
    if mean_log <= 0 or not np.isfinite(mean_log):
        return np.nan
    return 1.0 / mean_log


def fit_levy_stable_to_increments(dx, dy):
    """Fit a symmetric Lévy-stable distribution to combined x and y increments.
    
    Uses scipy.stats.levy_stable.fit with fixed loc=0 and beta=0 (symmetric).
    
    Parameters
    ----------
    dx : np.ndarray
        x-increments (m).
    dy : np.ndarray
        y-increments (m).
    
    Returns
    -------
    alpha_stable : float
        Stability index (dimensionless), in (0, 2].
    beta_stable : float
        Skewness parameter (dimensionless), in [-1, 1].
    scale : float
        Scale parameter (m).
    loc : float
        Location parameter (m).
    """
    combined = np.concatenate([dx, dy])
    combined = combined[np.isfinite(combined)]
    if len(combined) < 20:
        return np.nan, np.nan, np.nan, np.nan
    with warnings.catch_warnings():
        warnings.simplefilter('ignore')
        try:
            params = levy_stable.fit(combined, f0=None, f1=None, floc=0)
            alpha_stable, beta_stable, loc, scale = params
        except Exception:
            return np.nan, np.nan, np.nan, np.nan
    return alpha_stable, beta_stable, scale, loc


def compute_eamsd_alpha(arr, group_field, group_val, id_field, time_field, msd_field,
                        frac_start=0.10, frac_end=0.70):
    """Compute ensemble-averaged MSD and fit power-law exponent α_emp.
    
    Parameters
    ----------
    arr : np.ndarray
        Structured array.
    group_field : str
        Field name for grouping.
    group_val : scalar
        Group value.
    id_field : str
        Trajectory ID field.
    time_field : str
        Time field (s).
    msd_field : str
        MSD field (m^2).
    frac_start : float
        Start fraction of time range for fitting.
    frac_end : float
        End fraction of time range for fitting.
    
    Returns
    -------
    alpha_emp : float
        Fitted anomalous exponent (dimensionless).
    alpha_std : float
        Standard error of α_emp.
    times : np.ndarray
        Time array (s).
    eamsd : np.ndarray
        Ensemble-averaged MSD (m^2).
    """
    mask = arr[group_field] == group_val
    sub = arr[mask]
    times = np.sort(np.unique(sub[time_field]))
    traj_ids = np.unique(sub[id_field])
    T = len(times)
    msd_matrix = np.full((len(traj_ids), T), np.nan)
    for i, tid in enumerate(traj_ids):
        tmask = sub[id_field] == tid
        traj = sub[tmask]
        sort_idx = np.argsort(traj[time_field])
        msd_matrix[i] = traj[msd_field][sort_idx]
    eamsd = np.nanmean(msd_matrix, axis=0)
    i_start = max(1, int(frac_start * T))
    i_end = max(i_start + 3, int(frac_end * T))
    t_fit = times[i_start:i_end]
    msd_fit = eamsd[i_start:i_end]
    valid = (t_fit > 0) & (msd_fit > 0) & np.isfinite(msd_fit)
    if valid.sum() < 3:
        return np.nan, np.nan, times, eamsd
    log_t = np.log(t_fit[valid])
    log_msd = np.log(msd_fit[valid])
    coeffs, cov = np.polyfit(log_t, log_msd, 1, cov=True)
    return coeffs[0], np.sqrt(cov[0, 0]), times, eamsd


def compute_empirical_pdf(data, n_bins=80):
    """Compute empirical PDF using log-spaced bins for heavy-tailed data.
    
    Parameters
    ----------
    data : np.ndarray
        Positive values (absolute increments, m).
    n_bins : int
        Number of bins.
    
    Returns
    -------
    bin_centers : np.ndarray
        Bin centers (m).
    pdf : np.ndarray
        Normalized PDF values (1/m).
    """
    data = data[data > 0]
    if len(data) < 5:
        return np.array([]), np.array([])
    log_min = np.log10(np.percentile(data, 1))
    log_max = np.log10(np.percentile(data, 99.5))
    if log_min >= log_max:
        log_min = np.log10(np.min(data))
        log_max = np.log10(np.max(data))
    bins = np.logspace(log_min, log_max, n_bins + 1)
    counts, edges = np.histogram(data, bins=bins, density=True)
    centers = 0.5 * (edges[:-1] + edges[1:])
    valid = counts > 0
    return centers[valid], counts[valid]


def kl_divergence_empirical(data_p, data_q, n_bins=60):
    """Compute empirical KL divergence D_KL(P || Q) using shared bin edges.
    
    Parameters
    ----------
    data_p : np.ndarray
        Samples from distribution P (absolute increments, m).
    data_q : np.ndarray
        Samples from distribution Q (absolute increments, m).
    n_bins : int
        Number of bins for histogram estimation.
    
    Returns
    -------
    kl : float
        KL divergence (dimensionless, nats).
    """
    data_p = data_p[data_p > 0]
    data_q = data_q[data_q > 0]
    if len(data_p) < 10 or len(data_q) < 10:
        return np.nan
    combined = np.concatenate([data_p, data_q])
    log_min = np.log10(np.percentile(combined, 2))
    log_max = np.log10(np.percentile(combined, 98))
    if log_min >= log_max:
        return np.nan
    bins = np.logspace(log_min, log_max, n_bins + 1)
    p_counts, _ = np.histogram(data_p, bins=bins)
    q_counts, _ = np.histogram(data_q, bins=bins)
    p_counts = p_counts.astype(float) + 1e-10
    q_counts = q_counts.astype(float) + 1e-10
    p_norm = p_counts / p_counts.sum()
    q_norm = q_counts / q_counts.sum()
    mask = (p_norm > 1e-12) & (q_norm > 1e-12)
    kl = np.sum(p_norm[mask] * np.log(p_norm[mask] / q_norm[mask]))
    return kl


if __name__ == '__main__':
    data_dir = 'data/'
    pv, lw = load_datasets(data_dir)

    pv_n_values = [5, 10, 20, 40]
    lw_beta_values = [1.2, 1.5, 1.8, 2.5]
    lw_alpha_theory = {1.2: 1.8, 1.5: 1.5, 1.8: 1.2, 2.5: 1.0}
