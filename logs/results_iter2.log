            pv, 'n_vortices', nv, 'trajectory_id', 'time', 'msd_true')
        pv_alpha_emp[nv] = a
        pv_alpha_std[nv] = a_std
        pv_times_eamsd[nv] = times
        pv_eamsd[nv] = eamsd

    lw_alpha_emp = {}
    lw_alpha_std_fit = {}
    lw_times_eamsd = {}
    lw_eamsd = {}
