    long_idx_lw = max_lag_lw - 1
    eb_lw_all = {}
    print("=== LEVY WALK ERGODICITY-BREAKING PARAMETER ===")
    for beta in beta_list:
        mask_b = lw_group_vals == beta
        x2d_b = lw_x2d[mask_b]
