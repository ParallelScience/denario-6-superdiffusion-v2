    """
    rep_nv = 20
    rep_beta = 1.5

    mask_pv = pv['n_vortices'] == rep_nv
    sub_pv = pv[mask_pv]
    tids_pv = np.unique(sub_pv['trajectory_id'])

    all_x_noisy_pv = []
    all_y_noisy_pv = []
    all_x_true_pv = []
    all_y_true_pv = []
    for tid in tids_pv:
